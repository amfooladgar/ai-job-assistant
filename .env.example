# ==============================================================================
# Environment Variables Example for AI Job Scout Agent
# Copy this file to `.env` and fill in the values.
# ==============================================================================

# Gemini API Configuration (Google GenAI SDK)
GEMINI_API_KEY=your_gemini_api_key_here

# App settings
ENV=development
LOG_LEVEL=INFO

# Storage configurations (default is local SQLite)
DATABASE_PATH=data/job_scout.db

# Optional: Notification settings (future feature)
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=your_email@gmail.com
# EMAIL_RECEIVER=your_receiver_email@gmail.com
